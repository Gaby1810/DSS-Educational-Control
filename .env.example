# =========================================
# Educational Control - Variables de Entorno
# =========================================
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el archivo .env real al repositorio.

# --- BASE DE DATOS ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_password_aqui
DB_NAME=educational_control

# --- SERVIDOR ---
PORT=3000
NODE_ENV=development

# --- SESIONES ---
# Genera uno fuerte con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=cambia_este_secreto_por_uno_aleatorio_largo_de_minimo_64_caracteres

# --- CORS ---
# En producción cámbialo al dominio real (https://tu-dominio.com)
CORS_ORIGIN=http://localhost:3000

# --- SEGURIDAD ---
# Token secreto para crear el primer admin (úsalo solo una vez en /api/auth/registrar-admin)
ADMIN_REGISTRATION_TOKEN=token_unico_solo_para_crear_admins_inicial
